---
import GlassCard from './GlassCard.astro';
import Icon from './Icon.astro';

interface Props {
  title: string;        // may contain <em>
  body: string;
  ctaLabel?: string;
  ctaHref?: string;
  trust?: string[];
}
const {
  title,
  body,
  ctaLabel = 'Book a Free Demo',
  ctaHref = '/contact',
  trust = ['No contracts', 'Live in 7 days', 'Cancel anytime'],
} = Astro.props;
---

<section class="section cta-section">
  <div class="cta-bg" aria-hidden="true">
    <div class="backdrop-blob navy" style="width:520px;height:520px;top:-180px;left:50%;transform:translateX(-50%);opacity:0.4;"></div>
  </div>
  <div class="container">
    <GlassCard size="lg" class="cta-card" data-reveal>
      <h2 class="h2" set:html={title}></h2>
      <p class="lead">{body}</p>
      <a href={ctaHref} class="btn btn-primary btn-lg transition-link">{ctaLabel}</a>
      <div class="cta-trust">
        {trust.map((t) => (
          <span><Icon name="check" size={14} /> {t}</span>
        ))}
      </div>
    </GlassCard>
  </div>
</section>

<style>
  .cta-section { position: relative; padding: clamp(7rem, 12vw, 10rem) 0; overflow: hidden; }
  .cta-bg { position: absolute; inset: 0; pointer-events: none; }
  .cta-section .container { position: relative; z-index: 1; }
  .cta-card {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    padding: clamp(3rem, 6vw, 5rem) clamp(2rem, 5vw, 4rem);
  }
  .cta-card .h2 { margin-bottom: 22px; }
  .cta-card .lead { margin-bottom: 36px; }
  .cta-trust {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .cta-trust span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-eyebrow);
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .cta-trust :global(.icon) { color: var(--success); }
</style>
