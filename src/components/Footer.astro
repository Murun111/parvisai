---
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo transition-link" aria-label="Parvis AI home">
          <span class="logo-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5"/>
              <path d="M11 9v14M11 9h6.5a4 4 0 0 1 0 8H11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="logo-word">Parvis <em>AI</em></span>
        </a>
        <p class="footer-blurb">
          Intelligent AI employees for local businesses. One system that handles your calls, bookings, invoices, follow-ups, and customer relationships &mdash; 24/7.
        </p>
      </div>

      <div class="footer-col">
        <h4>Pages</h4>
        <a href="/" class="transition-link">Home</a>
        <a href="/services" class="transition-link">How It Works</a>
        <a href="/pricing" class="transition-link">Pricing</a>
        <a href="/contact" class="transition-link">Contact</a>
        <a href="/education" class="transition-link">Education</a>
      </div>

      <div class="footer-col">
        <h4>Solutions</h4>
        <a href="/services" class="transition-link">AI Voice Receptionist</a>
        <a href="/services" class="transition-link">Lead Follow-Up</a>
        <a href="/services" class="transition-link">Invoice Automation</a>
        <a href="/services" class="transition-link">Review Management</a>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <a href="mailto:hello@parvisai.com">hello@parvisai.com</a>
        <a href="tel:+18475550199">(847) 555-0199</a>
        <a href="/contact" class="transition-link">Get a Demo</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Parvis AI. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--rule);
    padding: clamp(4rem, 8vw, 5.5rem) 0 2.5rem;
    background: var(--bg-elev);
    position: relative;
  }
  footer::before {
    content: '';
    position: absolute;
    top: -1px; left: var(--gutter);
    width: 56px; height: 2px;
    background: var(--brand);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }

  .footer-brand .logo {
    display: inline-flex; align-items: center; gap: 10px;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.35rem; font-weight: 400;
  }
  .footer-brand .logo em { font-style: italic; color: var(--brand); }
  .logo-mark { width: 28px; height: 28px; color: var(--brand); display: inline-flex; }
  .logo-mark svg { width: 100%; height: 100%; }

  .footer-blurb {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin-top: 18px;
    max-width: 320px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 6px;
  }
  .footer-col a {
    font-size: 0.9rem;
    color: var(--ink-soft);
    transition: color 0.3s var(--ease);
  }
  .footer-col a:hover { color: var(--brand); }

  .footer-bottom {
    border-top: 1px solid var(--rule);
    padding-top: 24px;
    text-align: center;
  }
  .footer-bottom p {
    font-size: 0.78rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
