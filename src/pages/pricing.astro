---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Icon from '../components/Icon.astro';
import CtaSection from '../components/CtaSection.astro';

const tiers = [
  {
    name: 'Core',
    desc: 'Essential AI automation to start recovering leads.',
    price: '397',
    features: [
      'Missed call text-back',
      'Appointment reminders',
      'AI chat widget',
      'Review request automation',
      'Monthly performance report',
      'Email support',
    ],
    cta: 'Get Started',
    btnClass: 'btn-ghost',
    featured: false,
  },
  {
    name: 'Growth',
    desc: 'Full AI employee with voice, follow-ups, and re-engagement.',
    price: '797',
    features: [
      'Everything in Core',
      'AI voice receptionist',
      'Invoice + payment follow-up',
      'Lead nurture sequences',
      'Re-engagement campaigns',
      'Weekly performance report',
      'Priority support',
    ],
    cta: 'Get Started',
    btnClass: 'btn-primary',
    featured: true,
  },
  {
    name: 'Elite',
    desc: 'White-glove service with a fully customized AI persona.',
    price: '1,297',
    features: [
      'Everything in Growth',
      'Custom AI persona + name',
      'Full CRM + pipeline',
      'Social media automation',
      'Monthly system tuning',
      'Monthly strategy call',
      'Dedicated account manager',
    ],
    cta: 'Get Started',
    btnClass: 'btn-ghost',
    featured: false,
  },
];

const roi = [
  { biz: 'Dentist', lines: [
    { l: 'Avg customer value:', v: '$1,200/yr' },
    { l: 'Recovered leads/mo:', v: '5' },
    { l: 'Monthly revenue recovered:', v: '$6,000', highlight: true },
    { l: 'Parvis AI cost (Growth):', v: '-$797' },
    { l: 'Net gain:', v: '$5,203/mo', result: true },
  ]},
  { biz: 'HVAC Company', lines: [
    { l: 'Avg job value:', v: '$800' },
    { l: 'Recovered leads/mo:', v: '4' },
    { l: 'Monthly revenue recovered:', v: '$3,200', highlight: true },
    { l: 'Parvis AI cost (Growth):', v: '-$797' },
    { l: 'Net gain:', v: '$2,403/mo', result: true },
  ]},
  { biz: 'Salon', lines: [
    { l: 'Avg customer value:', v: '$75/visit' },
    { l: 'Recovered leads/mo:', v: '8' },
    { l: 'Monthly revenue recovered:', v: '$600', highlight: true },
    { l: 'Parvis AI cost (Core):', v: '-$397' },
    { l: 'Net gain:', v: '$203/mo', result: true },
  ]},
];

const faqs = [
  { q: 'Is there any setup required?', a: 'Setup is completely free and included with every plan. We configure your entire AI employee — train it on your business, set up all automations, connect your phone system, and get everything live within 7 days. You don\'t touch a thing.' },
  { q: 'Am I locked into a contract?', a: 'No contracts. Month-to-month. Cancel anytime with a simple email. We keep you because of results, not fine print.' },
  { q: 'Do I need to be tech-savvy?', a: 'Not at all. We handle everything. Your AI employee works in the background — you just see more appointments, more reviews, and faster payments.' },
  { q: 'Will customers know it\'s AI?', a: 'It\'s trained on your business voice and tone. To the customer, it feels like talking to your team. Messages come from your business number.' },
  { q: 'How fast will I see results?', a: 'Most clients see their first recovered lead within 24-48 hours of going live. Review growth and payment improvements typically start within the first week.' },
  { q: 'Can I upgrade my plan later?', a: 'Absolutely. You can upgrade from Core to Growth or Elite at any time. We\'ll configure the additional features and have them running within 48 hours.' },
  { q: 'What if it doesn\'t work for my business?', a: 'If you don\'t see ROI in the first 30 days, we\'ll refund your first month. No questions asked. We\'re that confident.' },
];

const compareSections = [
  { title: 'AI Capabilities', rows: [
    ['Missed Call Text-Back', true, true, true],
    ['AI Chat Widget', true, true, true],
    ['AI Voice Receptionist', false, true, true],
    ['Custom AI Persona + Name', false, false, true],
  ]},
  { title: 'Automations', rows: [
    ['Appointment Reminders', true, true, true],
    ['Review Request Automation', true, true, true],
    ['Invoice + Payment Follow-Up', false, true, true],
    ['Lead Nurture Sequences', false, true, true],
    ['Re-Engagement Campaigns', false, true, true],
    ['Social Media Automation', false, false, true],
  ]},
  { title: 'CRM & Tools', rows: [
    ['Contact Management', 'Basic', 'Full CRM', 'Full CRM + Pipeline'],
    ['Booking & Appointments', true, true, true],
  ]},
  { title: 'Reporting & Support', rows: [
    ['Performance Reports', 'Monthly', 'Weekly', 'Weekly'],
    ['Monthly System Tuning', false, false, true],
    ['Strategy Calls', false, false, 'Monthly'],
    ['Email Support', true, true, true],
    ['Priority Support', false, true, true],
    ['Dedicated Account Manager', false, false, true],
  ]},
];

function cellRender(v: boolean | string) {
  if (v === true) return '✓';
  if (v === false) return '—';
  return v;
}
---

<Base title="Pricing — Parvis AI" active="pricing">

  <PageHeader
    meta="03 — Pricing"
    title={`Simple, transparent <em>pricing.</em>`}
    lead="No hidden fees, no long-term contracts — cancel any time. Every plan includes a dedicated AI employee built specifically for your business."
  />

  <!-- PRICING CARDS -->
  <section class="section">
    <div class="container">
      <div class="pricing-grid">
        {tiers.map((tier) => (
          <GlassCard
            size="lg"
            hover={!tier.featured}
            class={`tier${tier.featured ? ' tier--featured' : ''}`}
            data-reveal
          >
            {tier.featured && <div class="tier-badge">Most Popular</div>}
            <div class="tier-name">{tier.name}</div>
            <div class="tier-desc">{tier.desc}</div>
            <div class="tier-price">
              <span class="currency">$</span>{tier.price}<span class="period">/mo</span>
            </div>
            <ul class="tier-features">
              {tier.features.map((f) => (
                <li><Icon name="check" size={14} /> {f}</li>
              ))}
            </ul>
            <a href="/contact" class={`btn ${tier.btnClass} btn-full transition-link`}>{tier.cta}</a>
          </GlassCard>
        ))}
      </div>

      <div class="pricing-note" data-reveal>
        <p><strong>Every plan includes:</strong> Free setup, a dedicated AI employee trained on your business, live within 7 days, no long-term contracts, cancel anytime.</p>
      </div>

      <!-- COMPARISON TABLE -->
      <div class="compare-wrap" data-reveal>
        <h3 class="compare-title">Compare Plans <em>Side by Side</em></h3>
        <div class="table-scroll">
          <table class="compare-table">
            <thead>
              <tr>
                <th class="feature-col">Feature</th>
                <th>Core<br/><span class="th-price">$397/mo</span></th>
                <th class="featured-col">Growth<br/><span class="th-price">$797/mo</span></th>
                <th>Elite<br/><span class="th-price">$1,297/mo</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Trained on Your Business</td>
                <td>✓</td>
                <td class="featured-col">✓</td>
                <td>✓</td>
              </tr>
              <tr>
                <td>Live Within 7 Days</td>
                <td>✓</td>
                <td class="featured-col">✓</td>
                <td>✓</td>
              </tr>
              {compareSections.map((sec) => (
                <>
                  <tr class="section-row"><td colspan="4">{sec.title}</td></tr>
                  {sec.rows.map((row) => (
                    <tr>
                      <td>{row[0]}</td>
                      <td>{cellRender(row[1])}</td>
                      <td class="featured-col">{cellRender(row[2])}</td>
                      <td>{cellRender(row[3])}</td>
                    </tr>
                  ))}
                </>
              ))}
            </tbody>
            <tfoot>
              <tr>
                <td></td>
                <td><a href="/contact" class="btn btn-ghost btn-table transition-link">Get Started</a></td>
                <td class="featured-col"><a href="/contact" class="btn btn-primary btn-table transition-link">Get Started</a></td>
                <td><a href="/contact" class="btn btn-ghost btn-table transition-link">Get Started</a></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI -->
  <section class="section section--paper">
    <div class="container">
      <div class="section-intro center" data-reveal>
        <Eyebrow>ROI Calculator</Eyebrow>
        <h2 class="h2">What's one new customer <em>worth to you?</em></h2>
        <p class="lead">Most local businesses make $200-$2,000+ per customer. If Parvis AI saves you just 3-5 leads a month, the math works itself out.</p>
      </div>
      <div class="roi-grid">
        {roi.map((card) => (
          <GlassCard size="md" hover={true} class="roi-card" data-reveal>
            <div class="roi-biz">{card.biz}</div>
            <div class="roi-math">
              {card.lines.map((line) => (
                <div class={`roi-line${line.result ? ' roi-result' : ''}`}>
                  <span>{line.l}</span>
                  <strong class={line.highlight ? 'roi-highlight' : ''}>{line.v}</strong>
                </div>
              ))}
            </div>
          </GlassCard>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-intro" data-reveal>
        <Eyebrow>FAQ</Eyebrow>
        <h2 class="h2">Questions? <em>We've got answers.</em></h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <div class="faq-item">
            <button class="faq-question">{item.q}</button>
            <div class="faq-answer"><p>{item.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaSection
    title="Ready to stop losing <em>leads to voicemail?</em>"
    body="Book a free 15-minute demo and we'll show you exactly what your Parvis AI employee would look like — no obligation, no hard sell."
    trust={["30-day guarantee", "No contracts", "Live in 7 days"]}
  />

</Base>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    align-items: stretch;
  }
  .tier {
    padding: 44px 36px;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .tier--featured {
    transform: translateY(-12px);
    border-color: var(--brand);
    background: var(--brand-soft);
  }
  .tier-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand);
    color: var(--bg);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    padding: 6px 18px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .tier-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .tier-desc {
    font-size: 0.88rem;
    color: var(--ink-muted);
    line-height: 1.5;
    margin-bottom: 24px;
    min-height: 2.6em;
  }
  .tier-price {
    font-family: var(--font-display);
    font-size: 3.4rem;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 28px;
  }
  .currency {
    font-size: 1.4rem;
    vertical-align: super;
    color: var(--ink-muted);
  }
  .period {
    font-size: 0.95rem;
    font-family: var(--font-sans);
    color: var(--ink-muted);
    font-weight: 400;
  }
  .tier-features {
    margin-bottom: 32px;
    flex: 1;
  }
  .tier-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    font-size: 0.9rem;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--rule);
  }
  .tier-features li:last-child { border-bottom: none; }
  .tier-features :global(.icon) { color: var(--success); flex-shrink: 0; }

  .pricing-note {
    text-align: center;
    margin-top: clamp(3rem, 5vw, 4rem);
    padding: 28px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: var(--bg-elev);
  }
  .pricing-note p { font-size: 0.92rem; color: var(--ink-muted); }
  .pricing-note strong { color: var(--ink); }

  /* Compare table */
  .compare-wrap { margin-top: clamp(3.5rem, 6vw, 5rem); }
  .compare-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    text-align: center;
    margin-bottom: 36px;
    color: var(--ink);
  }
  .compare-title em { color: var(--brand); font-style: italic; }
  .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    background: var(--bg-elev);
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    min-width: 660px;
  }
  .compare-table th, .compare-table td {
    padding: 16px 18px;
    text-align: center;
    border-bottom: 1px solid var(--rule);
  }
  .compare-table th {
    font-size: 0.95rem;
    font-weight: 600;
    padding-bottom: 22px;
    vertical-align: bottom;
    color: var(--ink);
  }
  .compare-table th.feature-col,
  .compare-table td:first-child {
    text-align: left;
    color: var(--ink);
    font-weight: 500;
    min-width: 220px;
  }
  .th-price {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--brand);
    margin-top: 4px;
  }
  .featured-col { background: var(--brand-soft); }
  .compare-table .section-row td {
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand);
    padding: 26px 18px 12px;
    background: transparent;
  }
  .compare-table tbody td { color: var(--ink-soft); }
  .compare-table tbody td:not(:first-child) { font-weight: 600; }
  .compare-table tfoot td { padding: 24px 18px; border-bottom: none; }
  .btn-table { padding: 9px 22px; font-size: 0.82rem; }

  /* ROI */
  .roi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .roi-card { padding: 36px 30px; }
  .roi-biz {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--brand);
    margin-bottom: 22px;
  }
  .roi-line {
    display: flex;
    justify-content: space-between;
    padding: 9px 0;
    font-size: 0.88rem;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
  }
  .roi-result {
    border-bottom: none;
    padding-top: 16px;
    margin-top: 8px;
    border-top: 1px solid var(--rule-strong);
  }
  .roi-result span,
  .roi-result strong { color: var(--ink); font-weight: 700; }
  .roi-highlight { color: var(--success) !important; }

  @media (max-width: 1024px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .tier--featured { transform: none; }
    .roi-grid { grid-template-columns: 1fr; }
  }
</style>
