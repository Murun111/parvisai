---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Icon from '../components/Icon.astro';
import GhlEmbed from '../components/GhlEmbed.astro';
---

<Base title="Get a Demo — Parvis AI" active="contact">

  <PageHeader
    meta="04 — Contact"
    title={`See Parvis AI in action with a <em>free demo.</em>`}
    lead="Fill out the form below. We'll reach out within 24 hours to schedule your personalized demo."
  />

  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- LEFT: process + contact info -->
        <aside class="contact-side" data-reveal>
          <GlassCard size="md" class="contact-info" padding="36px">
            <Eyebrow>What happens next</Eyebrow>
            <ol class="next-steps">
              <li>
                <span class="step-num">01</span>
                <div>
                  <strong>You fill out the form</strong>
                  <p>Takes 60 seconds.</p>
                </div>
              </li>
              <li>
                <span class="step-num">02</span>
                <div>
                  <strong>We call you</strong>
                  <p>Within 24 hours to schedule your demo.</p>
                </div>
              </li>
              <li>
                <span class="step-num">03</span>
                <div>
                  <strong>Live demo</strong>
                  <p>We show you the system working with your business number.</p>
                </div>
              </li>
              <li>
                <span class="step-num">04</span>
                <div>
                  <strong>You decide</strong>
                  <p>No pressure, no obligation.</p>
                </div>
              </li>
            </ol>
          </GlassCard>

          <GlassCard size="sm" class="contact-info-sm" padding="24px 28px">
            <h4 class="info-heading">Email</h4>
            <a class="info-link" href="mailto:hello@parvisai.com">hello@parvisai.com</a>
          </GlassCard>

          <GlassCard size="sm" class="contact-info-sm" padding="24px 28px">
            <h4 class="info-heading">Phone</h4>
            <a class="info-link" href="tel:+18475550199">(847) 555-0199</a>
          </GlassCard>

          <GlassCard size="md" class="contact-promise" padding="28px 30px">
            <h4 class="promise-title">Our Guarantee</h4>
            <ul class="promise-list">
              <li><Icon name="check" size={14} /> Free demo, no commitment</li>
              <li><Icon name="check" size={14} /> Free setup if you sign up</li>
              <li><Icon name="check" size={14} /> 30-day money-back guarantee</li>
              <li><Icon name="check" size={14} /> No contracts ever</li>
            </ul>
          </GlassCard>
        </aside>

        <!-- RIGHT: GoHighLevel form embed -->
        <div class="contact-form-wrap" data-reveal>
          <GlassCard size="lg" padding="clamp(20px, 3vw, 32px)">
            <h3 class="form-title">Request Your Free Demo</h3>
            <p class="form-subtitle">Tell us about your business and we'll show you exactly how Parvis AI will work for you.</p>
            <GhlEmbed
              type="form"
              src="https://api.leadconnectorhq.com/widget/form/okQR2mkzaikyoqHT8ByE"
              id="okQR2mkzaikyoqHT8ByE"
              title="Request your free Parvis AI demo"
            />
          </GlassCard>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .contact-side {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .next-steps {
    margin-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .next-steps li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--brand);
    line-height: 1;
    margin-top: 2px;
    min-width: 32px;
  }
  .next-steps strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .next-steps p {
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.5;
  }

  .info-heading {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 8px;
  }
  .info-link {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--ink);
    transition: color 0.3s var(--ease);
  }
  .info-link:hover { color: var(--brand); }

  .contact-promise {
    background: var(--brand-soft) !important;
    border-color: var(--brand-line) !important;
  }
  .promise-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--brand);
    margin-bottom: 14px;
  }
  .promise-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .promise-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
  .promise-list :global(.icon) { color: var(--success); }

  /* FORM */
  .form-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .form-subtitle {
    font-size: 0.9rem;
    color: var(--ink-muted);
    margin-bottom: 30px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--ink-muted);
    margin-bottom: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--rule-strong);
    border-radius: var(--radius-sm);
    background: var(--bg);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--ink);
    outline: none;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
    -webkit-appearance: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--brand);
    box-shadow: 0 0 0 4px var(--brand-soft);
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--ink-faint);
  }
  .form-group select {
    cursor: pointer;
    color: var(--ink-soft);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' fill='none' stroke='%230F1E45' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }
  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }
  .form-response {
    margin-top: 18px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-muted);
  }
  .form-response.success { color: var(--success); }

  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
