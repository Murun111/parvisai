---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Icon from '../components/Icon.astro';
import GhlEmbed from '../components/GhlEmbed.astro';
---

<Base title="Book a Demo — Parvis AI" active="contact">

  <PageHeader
    meta="04 — Book a Demo"
    title={`Pick a time. <em>We'll handle the rest.</em>`}
    lead="A 15-minute walkthrough — no slide deck, just your business and what your AI employee would do for you."
  />

  <section class="section">
    <div class="container">
      <div class="book-grid">

        <!-- LEFT: what to expect -->
        <aside class="book-side" data-reveal>
          <GlassCard size="md" class="book-info" padding="36px">
            <Eyebrow>What to expect</Eyebrow>
            <ol class="next-steps">
              <li>
                <span class="step-num">01</span>
                <div>
                  <strong>15 minutes, on a video call</strong>
                  <p>We send a calendar invite with the meeting link.</p>
                </div>
              </li>
              <li>
                <span class="step-num">02</span>
                <div>
                  <strong>Live demo with your business</strong>
                  <p>We pull up an example built around your industry.</p>
                </div>
              </li>
              <li>
                <span class="step-num">03</span>
                <div>
                  <strong>You decide</strong>
                  <p>No pressure, no contract. Most clients are live within 7 days if they move forward.</p>
                </div>
              </li>
            </ol>
          </GlassCard>

          <GlassCard size="md" class="book-promise" padding="28px 30px">
            <h4 class="promise-title">Our Guarantee</h4>
            <ul class="promise-list">
              <li><Icon name="check" size={14} /> Free demo, no commitment</li>
              <li><Icon name="check" size={14} /> Free setup if you sign up</li>
              <li><Icon name="check" size={14} /> 30-day money-back guarantee</li>
              <li><Icon name="check" size={14} /> No contracts ever</li>
            </ul>
          </GlassCard>

          <p class="book-fallback">
            Prefer to send details first? <a href="/contact" class="transition-link">Use the form instead →</a>
          </p>
        </aside>

        <!-- RIGHT: GHL booking calendar -->
        <div class="book-calendar-wrap" data-reveal>
          <GlassCard size="lg" padding="clamp(16px, 2.5vw, 28px)">
            <GhlEmbed
              type="booking"
              src="https://api.leadconnectorhq.com/widget/booking/uzH3dYSo4MyUOEyxkHDK"
              id="uzH3dYSo4MyUOEyxkHDK_1777560468694"
              title="Book a Parvis AI demo"
            />
          </GlassCard>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  .book-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .book-side {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .next-steps {
    margin-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .next-steps li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--brand);
    line-height: 1;
    margin-top: 2px;
    min-width: 32px;
  }
  .next-steps strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .next-steps p {
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.5;
  }

  .book-promise {
    background: var(--brand-soft) !important;
    border-color: var(--brand-line) !important;
  }
  .promise-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--brand);
    margin-bottom: 14px;
  }
  .promise-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .promise-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
  .promise-list :global(.icon) { color: var(--success); }

  .book-fallback {
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-align: center;
    margin-top: 8px;
  }
  .book-fallback a {
    color: var(--brand);
    border-bottom: 1px solid var(--brand-line);
    transition: opacity 0.3s var(--ease);
  }
  .book-fallback a:hover { opacity: 0.7; }

  @media (max-width: 1024px) {
    .book-grid { grid-template-columns: 1fr; }
  }
</style>
